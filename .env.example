# ─────────────────────────────────────────────────────────────
# BetterUs — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI provider (OpenAI-compatible). Two options:
#
# 1) OpenRouter + DeepSeek (what we're using):
OPENAI_API_KEY=sk-or-v1-xxxxxxxx
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=deepseek/deepseek-chat
#    Pick the exact model slug from https://openrouter.ai/models
#    e.g. deepseek/deepseek-chat-v3.1  or  deepseek/deepseek-chat-v3.1:free
#
# 2) Plain OpenAI instead (leave OPENAI_BASE_URL unset):
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Razorpay (https://dashboard.razorpay.com → Settings → API Keys)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your-key-secret
# Create Subscription Plans in the Razorpay dashboard and paste their ids.
# RAZORPAY_PLAN_ID is the fallback used when a tier-specific plan is unset.
RAZORPAY_PLAN_ID=plan_xxxxxxxx
RAZORPAY_PLAN_PRO=plan_xxxxxxxx        # ₹299/month
RAZORPAY_PLAN_PREMIUM=plan_xxxxxxxx    # ₹499/month
# Lifetime (₹999) is a one-time order — no plan id needed.
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# PostHog (https://posthog.com → Project Settings)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
